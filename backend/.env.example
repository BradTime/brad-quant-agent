# Server
PORT=3001
# 运行环境：dev / production（production 会强制关闭局域网 CORS、并要求非默认 JWT_SECRET）
APP_ENV=dev
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# 开发环境允许 192.168.x.x 等局域网前端（生产请设为 false）
CORS_ALLOW_PRIVATE_LAN=true

# Database (Postgres)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/quant_agent

# DeepSeek（OpenAI 兼容）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# RAG（检索增强）
# EMBEDDING_PROVIDER=local 用本地 sentence-transformers（默认 bge-small-zh，离线免费）
# 切 api 则填 EMBEDDING_API_BASE / EMBEDDING_API_KEY（OpenAI 兼容 embedding 接口）
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIM=512
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=
RAG_TOP_K=5
# RAG 总开关（关闭后早报/问答不做检索增强，不影响主流程）
RAG_ENABLED=true
# 启动时后台预热本地 embedding 模型（守护线程，不阻塞启动）
EMBEDDING_WARM_ON_START=true

# 盘前早报引擎：graph（LangGraph 多智能体）/ single（单轮兜底）
BRIEF_ENGINE=graph
# 可观测（LangSmith）：留空=关闭追踪（离线无依赖）；填 key 即自动开启
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=brad-quant-agent

# LLMQuant Data（早报"海外宏观"快照，经官方 MCP server `npx @llmquant/data-mcp`）
# 留空或运行环境无 npx 时自动降级（早报海外宏观显示"暂无数据接入"）
LLMQUANT_ENABLED=true
LLMQUANT_API_KEY=
LLMQUANT_BASE_URL=https://api.llmquantdata.com
LLMQUANT_MACRO_INDICATORS=us.cpi.headline,us.pce.core,us.unemployment_rate,us.rates.fed_funds,us.yield.10y,us.yield_curve.10y_2y
# 进程内 TTL 缓存秒数（默认 12h）：避免每次早报生成都 npx 取数 + 计费；调度器每日 08:00 预热
LLMQUANT_CACHE_TTL_SECONDS=43200
# 量化知识背景（wiki 语义检索）：给「消息面/研究分析师」补概念背景
LLMQUANT_KNOWLEDGE_ENABLED=true
LLMQUANT_KNOWLEDGE_TOPK=4
