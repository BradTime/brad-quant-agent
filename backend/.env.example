# Server
PORT=3001
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# 开发环境允许 192.168.x.x 等局域网前端（生产请设为 false）
CORS_ALLOW_PRIVATE_LAN=true

# Database (Postgres)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/quant_agent

# DeepSeek（OpenAI 兼容）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# RAG（检索增强）
# EMBEDDING_PROVIDER=local 用本地 sentence-transformers（默认 bge-small-zh，离线免费）
# 切 api 则填 EMBEDDING_API_BASE / EMBEDDING_API_KEY（OpenAI 兼容 embedding 接口）
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIM=512
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=
RAG_TOP_K=5

# 盘前早报引擎：graph（LangGraph 多智能体）/ single（单轮兜底）
BRIEF_ENGINE=graph
# 可观测（LangSmith）：留空=关闭追踪（离线无依赖）；填 key 即自动开启
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=brad-quant-agent
