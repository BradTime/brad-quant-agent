# Server
PORT=8000
# 运行环境：dev / production（production 会强制关闭局域网 CORS、并校验 JWT 密钥强度）
APP_ENV=dev
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# 开发环境允许 192.168.x.x 等局域网前端（生产请设为 false）
CORS_ALLOW_PRIVATE_LAN=true

# Database (Postgres)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/quant_agent

# DeepSeek（OpenAI 兼容）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# JWT：生产仅接受 64 位 hex，或解码后 >=32 字节的 base64url；算法白名单仅 HS256
# 生成示例：openssl rand -hex 32
# base64url：openssl rand -base64 48 | tr '+/' '-_' | tr -d '=\n'
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 认证限流（Postgres 持久化、多 worker 安全）
AUTH_LOGIN_LIMIT=5
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_LOCK_SECONDS=900
AUTH_REGISTER_LIMIT=10
AUTH_REGISTER_WINDOW_SECONDS=3600
# dev/test 默认 true；production 强制 false
AUTH_AUTO_VERIFY_REGISTRATION=true
AUTH_VERIFICATION_EXPIRE_HOURS=24
# 默认不信任 X-Forwarded-For；仅填写实际反向代理网段（CIDR，逗号分隔）
# 例：AUTH_TRUSTED_PROXIES=10.20.0.0/16,2001:db8:1234::/48
AUTH_TRUSTED_PROXIES=

# 邮箱验证（production 必填；不提供邮件服务的 dev/test 可使用自动验证）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true
# production 必须为 https://，邮件验证链接拒绝 HTTP
FRONTEND_URL=http://localhost:3000

# 行情与模拟交易门禁
QUOTE_REFRESH_SECONDS=10
# data asOf 与缓存刷新时间任一超龄，均不可用于撮合（秒）
QUOTE_TRADE_MAX_AGE_SECONDS=60
# CI / 离线运行设为 false，禁止按需调用免费实时源
ENABLE_REALTIME_FETCH=true

# RAG（检索增强）
# EMBEDDING_PROVIDER=local 用本地 sentence-transformers（默认 bge-small-zh，离线免费）
# 切 api 则填 EMBEDDING_API_BASE / EMBEDDING_API_KEY（OpenAI 兼容 embedding 接口）
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIM=512
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=
RAG_TOP_K=5
# RAG 总开关（关闭后早报/问答不做检索增强，不影响主流程）
RAG_ENABLED=true
# 启动时后台预热本地 embedding 模型（守护线程，不阻塞启动）
EMBEDDING_WARM_ON_START=true
# 混合检索：向量召回 + 关键词(ILIKE)召回，RRF 融合排序（false=纯向量）
RAG_HYBRID_ENABLED=true
# 混合检索每路候选池大小（融合后截断到 RAG_TOP_K）
RAG_HYBRID_CANDIDATES=20
# HNSW 检索精度 ef_search（越大越准越慢；需已建 HNSW 索引才生效）
RAG_HNSW_EF_SEARCH=64
# embedding 分批大小（回填/长文）
EMBEDDING_BATCH_SIZE=64

# 进程角色：all=单体（默认）；api=仅 HTTP/WS；worker=调度+embedding 预热+回测队列
# 拆部署示例：api 容器 PROCESS_ROLE=api，worker 容器 PROCESS_ROLE=worker（两者共享 DATABASE_URL）
PROCESS_ROLE=all
# 回测网格任务队列轮询间隔（秒）；all/worker 进程内消费线程使用
BACKTEST_JOB_POLL_SECONDS=1.0
# 数据库连接池（Postgres）
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_TIMEOUT_SECONDS=30

# 深度研究：子问题上限 / 并发 / 总 deadline 秒（<=0 不限）
RESEARCH_MAX_SUBQUESTIONS=4
RESEARCH_SUBQUESTION_CONCURRENCY=2
RESEARCH_DEADLINE_SECONDS=180

# 盘前早报引擎：graph（LangGraph 多智能体）/ single（单轮兜底）
BRIEF_ENGINE=graph
# 早报新闻：主窗口小时数 / 回退最大年龄小时数（超出则标近期新闻缺失）
BRIEF_NEWS_WINDOW_HOURS=48
BRIEF_NEWS_MAX_FALLBACK_AGE_HOURS=168
# AI 成本闸：每用户每日生成配额（<=0 不限）+ 重型生成最小间隔秒（防超额/连点）
AI_DAILY_QUOTA_CHAT=100
AI_DAILY_QUOTA_RESEARCH=20
AI_DAILY_QUOTA_BRIEF=20
AI_HEAVY_MIN_INTERVAL_SEC=5
# 可观测（LangSmith）：留空=关闭追踪（离线无依赖）；填 key 即自动开启
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=brad-quant-agent
# 可观测（Sentry）：留空=不启用（零开销、不外联）；填 DSN 即开启错误/性能上报
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# LLMQuant Data（早报"海外宏观"快照，经官方 MCP server `npx @llmquant/data-mcp`）
# 留空或运行环境无 npx 时自动降级（早报海外宏观显示"暂无数据接入"）
LLMQUANT_ENABLED=true
LLMQUANT_API_KEY=
LLMQUANT_BASE_URL=https://api.llmquantdata.com
# 必须钉死版本（含 @x.y.z），禁止拉 latest
LLMQUANT_MCP_PACKAGE=@llmquant/data-mcp@0.5.2
LLMQUANT_MACRO_INDICATORS=us.cpi.headline,us.pce.core,us.unemployment_rate,us.rates.fed_funds,us.yield.10y,us.yield_curve.10y_2y
# 进程内 TTL 缓存秒数（默认 12h）：避免每次早报生成都 npx 取数 + 计费；调度器每日 08:00 预热
LLMQUANT_CACHE_TTL_SECONDS=43200
# 量化知识背景（wiki 语义检索）：给「消息面/研究分析师」补概念背景
LLMQUANT_KNOWLEDGE_ENABLED=true
LLMQUANT_KNOWLEDGE_TOPK=4
